<Window x:Class="Budget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Budget.Controls"
        mc:Ignorable="d"
        Title="Budget"
        Icon="pack://application:,,,/Assets/Budget.ico"
        Width="1180"
        Height="800"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.16" Color="{DynamicResource CardShadowColor}" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource SummaryBackgroundBrush}" />
        </Style>

        <Style x:Key="HeadingText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Hint"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Opacity="0.55"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Hint" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentInteractiveBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentInteractiveHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentInteractiveHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource DangerHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ToolbarHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ToolbarHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EmptyStateText" TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,2,0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="InlineEditBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="Click to edit" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Hint"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Opacity="0.55"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                                <ScrollViewer x:Name="PART_ContentHost" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Hint" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryEditBox" TargetType="TextBox" BasedOn="{StaticResource InlineEditBox}">
            <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="ToolTip" Value="Category — click to edit" />
        </Style>

        <Style x:Key="MiniLabelText" TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="BudgetListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Focusable" Value="False" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource HeadingText}" Text="Budget planner" />
                    <TextBlock Margin="0,10,0,0"
                               Style="{StaticResource SubtleText}"
                               FontSize="15"
                               Text="Enter your monthly take-home pay, then add every recurring expense and savings goal below." />

                    <StackPanel Margin="0,24,0,0" HorizontalAlignment="Left">
                        <TextBlock Style="{StaticResource LabelText}" Text="Budget month" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource ToolbarButton}"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12"
                                    Content="&#xE76B;"
                                    Padding="14,12"
                                    Margin="0,0,8,0"
                                    Command="{Binding PreviousMonthCommand}"
                                    ToolTip="Previous month" />
                            <Border MinWidth="170"
                                    Height="42"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="16,0">
                                <TextBlock VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding CurrentMonthLabel}" />
                            </Border>
                            <Button Style="{StaticResource ToolbarButton}"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="12"
                                    Content="&#xE76C;"
                                    Padding="14,12"
                                    Margin="8,0,0,0"
                                    Command="{Binding NextMonthCommand}"
                                    ToolTip="Next month" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Margin="0,18,0,0" Width="420" HorizontalAlignment="Left">
                        <TextBlock Style="{StaticResource LabelText}" Text="Monthly take-home pay" />
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding MonthlyTakeHomePayText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="e.g. $3,200"
                                 FontSize="18"
                                 HorizontalContentAlignment="Left" />
                    </StackPanel>

                    <TextBlock Margin="0,16,0,0"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Text="{Binding BudgetSummaryMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SubtleText}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleText}"
                               FontSize="13"
                               Text="Tip: use currency values like 3200, 3200.50, or $3,200.50." />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="24,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,14">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource LabelText}" Text="Theme" Margin="0,0,0,6" />
                            <ComboBox Width="150"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button Content="Import"
                                    Click="ImportBudgetClick"
                                    Style="{StaticResource ToolbarButton}"
                                    ToolTip="Import a budget from a JSON or CSV file" />
                            <Button Content="Export"
                                    Click="ExportBudgetClick"
                                    Style="{StaticResource ToolbarButton}"
                                    Margin="0"
                                    ToolTip="Export your budget to a JSON or CSV file" />
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Columns="2" Rows="2">
                        <Border Style="{StaticResource SummaryCardStyle}" Margin="0,0,12,12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Take-home pay" />
                                <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding MonthlyTakeHomePayDisplay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryCardStyle}" Margin="12,0,0,12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Planned deductions" />
                                <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding TotalDeductionsDisplay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryCardStyle}" Margin="0,12,12,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Leftover" />
                                <TextBlock FontSize="28" FontWeight="SemiBold" Text="{Binding LeftoverDisplay}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SummaryCardStyle}" Margin="12,12,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelText}" Text="Usage" />
                                <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding BudgetUsageDisplay}" />
                                <ProgressBar Height="8"
                                             Margin="0,10,0,2"
                                             Maximum="100"
                                             Value="{Binding BudgetUsagePercent, Mode=OneWay}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UsageSeverity}" Value="High">
                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding UsageSeverity}" Value="Over">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,2,0,0">
            <TabItem Header="Budget">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="OnTabScrollPreviewMouseWheel">
                    <StackPanel Margin="0,14,0,0">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="0.85*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Add a line item" />
                                    <TextBlock Margin="0,8,0,18"
                                               Style="{StaticResource SubtleText}"
                                               FontSize="14"
                                               Text="Group expenses by category and watch the category chart update automatically." />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.1*" />
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Line item name" />
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Tag="e.g. Rent"
                                                     Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Category" />
                                            <ComboBox IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      ItemsSource="{Binding CategoryOptions}"
                                                      Text="{Binding NewItemCategory, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Amount" />
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Tag="0.00"
                                                     Text="{Binding NewItemAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalContentAlignment="Right" />
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                MinWidth="150"
                                                VerticalAlignment="Bottom"
                                                Content="Add item"
                                                Command="{Binding AddLineItemCommand}"
                                                Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource SummaryCardStyle}"
                                        Margin="18,0,0,0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource HeadingText}" FontSize="20" Text="Spending by category" />
                                        <TextBlock Margin="0,6,0,16"
                                                   Style="{StaticResource SubtleText}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding SpendingSummaryMessage}" />
                                        <TextBlock Text="Nothing to chart yet — add a line item to see category totals.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CategorySummaries.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ItemsControl ItemsSource="{Binding CategorySummaries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,14">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       Text="{Binding Category}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="{Binding DetailText}" />
                                                        </Grid>
                                                        <ProgressBar Margin="0,8,0,0"
                                                                     Maximum="100"
                                                                     Value="{Binding ConsumptionPercent, Mode=OneWay}">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Over">
                                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Budget line items" />
                                <TextBlock Margin="0,8,0,18"
                                           Style="{StaticResource SubtleText}"
                                           FontSize="14"
                                           Text="Each item is assigned to a category so you can see where your money is going." />

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LineItems.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Style="{StaticResource SubtleText}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Text="{Binding CurrentMonthLabel, StringFormat=No line items for {0} yet — add your first expense above.}" />
                                    <Button Margin="0,10,0,4"
                                            HorizontalAlignment="Left"
                                            Content="Copy last month's plan"
                                            Style="{StaticResource ToolbarButton}"
                                            Command="{Binding CopyPreviousMonthCommand}"
                                            ToolTip="Copies the most recent earlier month's pay and line items into this month" />
                                </StackPanel>

                                <ListView Background="Transparent"
                                          BorderThickness="0"
                                          ItemsSource="{Binding LineItems}"
                                          ItemContainerStyle="{StaticResource BudgetListItem}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12"
                                                    Padding="18"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="20">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel HorizontalAlignment="Left">
                                                        <TextBox Style="{StaticResource InlineEditBox}"
                                                                 FontSize="15"
                                                                 FontWeight="SemiBold"
                                                                 MinWidth="180"
                                                                 HorizontalAlignment="Left"
                                                                 Margin="-8,0,0,0"
                                                                 Text="{Binding Name}"
                                                                 ToolTip="Name — click to edit" />
                                                        <TextBox Style="{StaticResource CategoryEditBox}"
                                                                 HorizontalAlignment="Left"
                                                                 Margin="-8,4,0,0"
                                                                 Text="{Binding Category}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource MiniLabelText}" HorizontalAlignment="Right" Text="Planned" />
                                                        <TextBox Style="{StaticResource InlineEditBox}"
                                                                 Width="110"
                                                                 FontWeight="SemiBold"
                                                                 HorizontalContentAlignment="Right"
                                                                 Text="{Binding PlannedAmountText}"
                                                                 ToolTip="Planned amount — click to edit" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource MiniLabelText}" HorizontalAlignment="Right" Text="Spent" />
                                                        <TextBox Style="{StaticResource InlineEditBox}"
                                                                 Width="110"
                                                                 HorizontalContentAlignment="Right"
                                                                 Text="{Binding ActualAmountText}"
                                                                 ToolTip="Total spent so far this month — click to edit" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Margin="18,0,18,0" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource MiniLabelText}" Text="Add spending" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBox Style="{StaticResource InlineEditBox}"
                                                                     Width="100"
                                                                     BorderBrush="{DynamicResource BorderBrushSoft}"
                                                                     HorizontalContentAlignment="Right"
                                                                     Tag="0.00"
                                                                     Text="{Binding SpendingText, UpdateSourceTrigger=PropertyChanged}"
                                                                     ToolTip="Amount to add to this item's Spent total" />
                                                            <Button Margin="8,0,0,0"
                                                                    Padding="14,7"
                                                                    Content="Add"
                                                                    FontSize="12"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Command="{Binding DataContext.RecordSpendingCommand, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Add this amount to what you've spent on this item" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Button Grid.Column="4"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveLineItemCommand, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Remove"
                                                            Style="{StaticResource DangerButton}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Goals">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="OnTabScrollPreviewMouseWheel">
                    <StackPanel Margin="0,14,0,0">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="0.85*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Savings goals" />
                                    <TextBlock Margin="0,8,0,6"
                                               Style="{StaticResource SubtleText}"
                                               FontSize="14"
                                               Text="Create goals, set targets, and track how close you are to reaching them." />
                                    <TextBlock Margin="0,0,0,18"
                                               Style="{StaticResource SubtleText}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Text="{Binding LeftoverDisplay, StringFormat=Leftover this month: {0} — contribute it to a goal below.}" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Goal name" />
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Tag="e.g. Emergency fund"
                                                     Text="{Binding NewGoalName, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Target" />
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Tag="5,000"
                                                     Text="{Binding NewGoalTargetAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalContentAlignment="Right" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Saved so far" />
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Tag="0.00"
                                                     Text="{Binding NewGoalSavedAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalContentAlignment="Right" />
                                        </StackPanel>

                                        <Button Grid.Column="3"
                                                MinWidth="150"
                                                VerticalAlignment="Bottom"
                                                Content="Add goal"
                                                Command="{Binding AddGoalCommand}"
                                                Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </StackPanel>

                                <UniformGrid Grid.Column="1" Columns="2" Rows="2" Margin="18,0,0,0">
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Target total" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding TotalGoalTargetDisplay}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="12,0,0,12">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Saved total" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding TotalGoalSavedDisplay}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="0,12,12,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Goal progress" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding SavingsGoalProgressDisplay}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="12,12,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Goals count" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding SavingsGoals.Count}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Goal progress chart" />
                                <TextBlock Margin="0,8,0,18"
                                           Style="{StaticResource SubtleText}"
                                           FontSize="14"
                                           Text="Each goal shows a live progress bar against its target." />

                                <TextBlock Text="No savings goals yet — create one above to start tracking progress.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SavingsGoals.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ItemsControl ItemsSource="{Binding SavingsGoals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,14"
                                                    Padding="18"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="20">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBox Style="{StaticResource InlineEditBox}"
                                                                 FontSize="15"
                                                                 FontWeight="SemiBold"
                                                                 MinWidth="180"
                                                                 HorizontalAlignment="Left"
                                                                 Margin="-8,0,0,0"
                                                                 Text="{Binding Name}"
                                                                 ToolTip="Name — click to edit" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="{Binding ProgressDisplay, StringFormat={}{0} funded}" />
                                                            <TextBlock FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="{Binding ProgressRemainingDisplay, StringFormat=' · {0} to go'}" />
                                                        </StackPanel>
                                                        <ProgressBar Margin="0,10,0,0"
                                                                     Maximum="100"
                                                                     Value="{Binding ProgressPercent, Mode=OneWay}">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ProgressPercent}" Value="100">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource MiniLabelText}" HorizontalAlignment="Right" Text="Saved" />
                                                        <TextBox Style="{StaticResource InlineEditBox}"
                                                                 Width="110"
                                                                 HorizontalContentAlignment="Right"
                                                                 Text="{Binding SavedAmountText}"
                                                                 ToolTip="Saved so far — click to edit" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource MiniLabelText}" HorizontalAlignment="Right" Text="Target" />
                                                        <TextBox Style="{StaticResource InlineEditBox}"
                                                                 Width="110"
                                                                 HorizontalContentAlignment="Right"
                                                                 Text="{Binding TargetAmountText}"
                                                                 ToolTip="Target amount — click to edit" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Margin="18,0,18,0" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource MiniLabelText}" Text="Contribute" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBox Style="{StaticResource InlineEditBox}"
                                                                     Width="100"
                                                                     BorderBrush="{DynamicResource BorderBrushSoft}"
                                                                     HorizontalContentAlignment="Right"
                                                                     Tag="0.00"
                                                                     Text="{Binding ContributionText, UpdateSourceTrigger=PropertyChanged}"
                                                                     ToolTip="Amount to add to this goal" />
                                                            <Button Margin="8,0,0,0"
                                                                    Padding="14,7"
                                                                    Content="Add"
                                                                    FontSize="12"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Command="{Binding DataContext.ContributeToGoalCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="Add this amount to the goal's savings" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <Button Grid.Column="4"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveGoalCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Remove"
                                                            Style="{StaticResource DangerButton}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Income">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PreviewMouseWheel="OnTabScrollPreviewMouseWheel">
                    <StackPanel Margin="0,14,0,0">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="0.85*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Monthly income tracker" />
                                    <TextBlock Margin="0,8,0,18"
                                               Style="{StaticResource SubtleText}"
                                               FontSize="14"
                                               Text="Track your monthly income over time and compare it with your budget." />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.3*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Month" />
                                            <DatePicker SelectedDate="{Binding NewIncomeMonth, Mode=TwoWay}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Style="{StaticResource LabelText}" Text="Income" />
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Tag="0.00"
                                                     Text="{Binding NewIncomeAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalContentAlignment="Right" />
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                MinWidth="150"
                                                VerticalAlignment="Bottom"
                                                Content="Add month"
                                                Command="{Binding AddIncomeEntryCommand}"
                                                Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </StackPanel>

                                <UniformGrid Grid.Column="1" Columns="2" Rows="2" Margin="18,0,0,0">
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="0,0,12,12">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Records" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding IncomeEntries.Count}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="12,0,0,12">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Latest income" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding LatestIncomeDisplay}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="0,12,12,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Total tracked" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding MonthlyIncomeHistoryTotalDisplay}" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource SummaryCardStyle}" Margin="12,12,0,0">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}" Text="Average" />
                                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding MonthlyIncomeHistoryAverageDisplay}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Income over time" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Text="{Binding IncomeChangeDisplay}"
                                               ToolTip="Latest month compared with the one before it">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IncomeChangeDirection}" Value="Up">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IncomeChangeDirection}" Value="Down">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IncomeChangeDirection}" Value="None">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <TextBlock Margin="0,8,0,18"
                                           Style="{StaticResource SubtleText}"
                                           FontSize="14"
                                           Text="Each month's income plotted like a stock ticker — hover the chart to read a month's exact amount." />

                                <TextBlock Text="No income recorded yet — add a month above to see the trend.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IncomeTrendItems.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <controls:IncomeTickerChart Height="260"
                                                            ItemsSource="{Binding IncomeTrendItems}"
                                                            LineBrush="{DynamicResource ChartLineBrush}"
                                                            GridLineBrush="{DynamicResource BorderBrushSoft}"
                                                            LabelBrush="{DynamicResource TextSecondaryBrush}"
                                                            ValueBrush="{DynamicResource TextPrimaryBrush}"
                                                            SurfaceBrush="{DynamicResource SurfaceBrush}">
                                    <controls:IncomeTickerChart.Style>
                                        <Style TargetType="controls:IncomeTickerChart">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IncomeTrendItems.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:IncomeTickerChart.Style>
                                </controls:IncomeTickerChart>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HeadingText}" FontSize="22" Text="Income records" />
                                <TextBlock Margin="0,8,0,18"
                                           Style="{StaticResource SubtleText}"
                                           FontSize="14"
                                           Text="Use this list to manage the months you have entered." />

                                <TextBlock Text="No months tracked yet.">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource EmptyStateText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IncomeEntries.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ListView Background="Transparent"
                                          BorderThickness="0"
                                          ItemsSource="{Binding IncomeEntries}"
                                          ItemContainerStyle="{StaticResource BudgetListItem}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12"
                                                    Padding="18"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="20">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Text="{Binding MonthLabel}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="Monthly income entry" />
                                                    </StackPanel>

                                                    <TextBox Grid.Column="1"
                                                             Margin="18,0,18,0"
                                                             VerticalAlignment="Center"
                                                             Width="130"
                                                             FontSize="15"
                                                             FontWeight="SemiBold"
                                                             HorizontalContentAlignment="Right"
                                                             Style="{StaticResource InlineEditBox}"
                                                             Text="{Binding AmountText}"
                                                             ToolTip="Income for this month — click to edit" />

                                                    <Button Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveIncomeEntryCommand, RelativeSource={RelativeSource AncestorType={x:Type ListView}}}"
                                                            CommandParameter="{Binding}"
                                                            Content="Remove"
                                                            Style="{StaticResource DangerButton}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                Style="{StaticResource CardStyle}"
                Padding="20,14"
                Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage}" />
                <Button Grid.Column="1"
                        Margin="14,0,0,0"
                        Content="Undo"
                        Command="{Binding UndoRemoveCommand}"
                        ToolTip="Restore the last removed entry">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Margin" Value="14,0,0,0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUndoAvailable}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

