<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="using:Budget.Infrastructure"
             x:Class="Budget.App"
             RequestedThemeVariant="Light">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF4F7FB" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF8FAFD" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFE3E9F2" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF122033" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF60708B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
        <SolidColorBrush x:Key="AccentBrushDark" Color="#FF2563EB" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#FFDBEAFE" />
        <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="AccentInteractiveBrush" Color="#FF2563EB" />
        <SolidColorBrush x:Key="AccentInteractiveHoverBrush" Color="#FF1D4ED8" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FF991B1B" />
        <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FFE2E8F0" />
        <SolidColorBrush x:Key="ToolbarHoverBrush" Color="#FFD7E0EA" />
        <SolidColorBrush x:Key="DangerBackgroundBrush" Color="#FFFEE2E2" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#FFFECACA" />
        <SolidColorBrush x:Key="SummaryBackgroundBrush" Color="#FFF9FBFE" />
        <SolidColorBrush x:Key="StatusBackgroundBrush" Color="#FFF8FAFD" />
        <SolidColorBrush x:Key="ChartLineBrush" Color="#FF3B82F6" />
        <Color x:Key="CardShadowColor">#1A0F172A</Color>

        <infra:ValueMatchConverter x:Key="Matches" />
        <infra:ValueMatchConverter x:Key="NotMatches" Negate="True" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ================= Cards ================= -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BoxShadow" Value="0 4 24 0 #26000000" />
        </Style>

        <Style Selector="Border.summary">
            <Setter Property="Background" Value="{DynamicResource SummaryBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 2 14 0 #1F000000" />
        </Style>

        <Style Selector="Border.row">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <!-- ================= Text ================= -->
        <Style Selector="TextBlock.heading">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="TextBlock.subtle">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style Selector="TextBlock.mini">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style Selector="TextBlock.empty">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,2,0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ================= Buttons ================= -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentInteractiveBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="18,12" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentInteractiveHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentInteractiveBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentInteractiveBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource DangerBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="Button.danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="Button.danger:pressed">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.danger:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ToolbarHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ToolbarHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.toolbar:pressed">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <!-- ================= Text boxes ================= -->
        <Style Selector="TextBox.modern">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox.modern:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style Selector="TextBox.modern:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="TextBox.inline">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox.inline:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>
        <Style Selector="TextBox.inline:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="TextBox.boxed">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
        </Style>

        <Style Selector="TextBox.chip">
            <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="MinWidth" Value="90" />
        </Style>

        <!-- ================= Category auto-complete (editable combo stand-in) ================= -->
        <Style Selector="AutoCompleteBox">
            <Setter Property="MinHeight" Value="44" />
        </Style>
        <Style Selector="AutoCompleteBox /template/ TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- ================= Combo box / date picker chrome ================= -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="CalendarDatePicker">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- ================= Tabs: pill-style headers ================= -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Bd"
                            Background="Transparent"
                            CornerRadius="12"
                            Padding="20,11"
                            Margin="0,0,8,4">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#Bd">
            <Setter Property="Background" Value="{DynamicResource ToolbarBackgroundBrush}" />
        </Style>
        <Style Selector="TabItem:selected /template/ Border#Bd">
            <Setter Property="Background" Value="{DynamicResource AccentInteractiveBrush}" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
        </Style>

        <!-- ================= Progress meters ================= -->
        <Style Selector="ProgressBar">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="10" />
            <Setter Property="Height" Value="10" />
        </Style>
        <Style Selector="ProgressBar.warn">
            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
        </Style>
        <Style Selector="ProgressBar.over">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
        </Style>
        <Style Selector="ProgressBar.complete">
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
        </Style>

        <!-- ================= Tooltips ================= -->
        <Style Selector="ToolTip">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Application.Styles>
</Application>
