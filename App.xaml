<Application x:Class="Budget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFF4F7FB" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF8FAFD" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#FFE3E9F2" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF122033" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF60708B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
        <SolidColorBrush x:Key="AccentBrushDark" Color="#FF2563EB" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF16A34A" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF59E0B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FFDC2626" />
        <Color x:Key="CardShadowColor">#1A0F172A</Color>
    </Application.Resources>
</Application>

